rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read/write access to MasjidBakrie collection for testing
    // IMPORTANT: Update these rules for production!
    match /MasjidBakrie/{document=**} {
      allow read, write: if true;
    }
    
    // Allow read access to hadiths collection (public display)
    // Write access should be restricted to authenticated admins in production
    match /hadiths/{document=**} {
      allow read: if true;
      allow write: if true; // Change this to authenticated users only in production
    }
    
    // Alternative: If you want authentication later
    // match /MasjidBakrie/{document=**} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null;
    // }
  }
}
